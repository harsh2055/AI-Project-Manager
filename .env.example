# ════════════════════════════════════════════
#  AI PROJECT MANAGER — Environment Variables
# ════════════════════════════════════════════

# ── Database ─────────────────────────────────
# PostgreSQL (production)
DATABASE_URL=postgresql://ai_pm_user:yourpassword@localhost:5432/ai_pm_db
# SQLite (local dev fallback — leave DATABASE_URL unset or use this)
# DATABASE_URL=sqlite:///./ai_pm.db

# ── Redis / Celery ────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-long-random-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── AI Provider ───────────────────────────────
# Choose one: groq | together | hf | ollama | nvidia
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
TOGETHER_API_KEY=your_together_api_key_here
HF_API_KEY=your_huggingface_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
OLLAMA_API_URL=http://localhost:11434/v1/chat/completions
OLLAMA_MODEL=llama3

# ── GitHub ────────────────────────────────────
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
ENABLE_GH_COMMENTS=false

# ── App ───────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
TEMP_DIR=/tmp/ai_pm_repos
PYTHONPATH=.
